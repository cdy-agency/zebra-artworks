{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "resolveJsonModule": true,

    "types": ["node"],   // ✅ THIS FIXES YOUR ERROR

    "baseUrl": "..",
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}